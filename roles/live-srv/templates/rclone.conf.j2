# rclone configuration for BAR Live Services backups
# Generated by Ansible

[backup]
{% if backup_storage_type == 's3' %}
type = s3
provider = {{ backup_s3_provider | default('AWS') }}
access_key_id = {{ backup_s3_access_key }}
secret_access_key = {{ backup_s3_secret_key }}
{% if backup_s3_region is defined %}
region = {{ backup_s3_region }}
{% endif %}
{% if backup_s3_endpoint is defined %}
endpoint = {{ backup_s3_endpoint }}
{% endif %}
{% elif backup_storage_type == 'b2' %}
type = b2
account = {{ backup_b2_account }}
key = {{ backup_b2_key }}
{% elif backup_storage_type == 'sftp' %}
type = sftp
host = {{ backup_sftp_host }}
user = {{ backup_sftp_user }}
{% if backup_sftp_key_file is defined %}
key_file = {{ backup_sftp_key_file }}
{% endif %}
{% if backup_sftp_pass is defined %}
pass = {{ backup_sftp_pass }}
{% endif %}
{% else %}
# Default to local filesystem for testing
type = local
{% endif %}
